# ELIMINAR WEBVIEW2
$VersionsToRemove = @("100.0.1185.36", "147.0.3912.72")

foreach ($Version in $VersionsToRemove) {
    $UninstallPath = "C:\Program Files (x86)\Microsoft\EdgeWebView\Application\$Version\Installer\setup.exe"
    
    if (Test-Path $UninstallPath) {
        Write-Host "Eliminando versión $Version..." -ForegroundColor Cyan
        Start-Process -FilePath $UninstallPath -ArgumentList "--uninstall --msedgewebview --system-level --force-uninstall" -Wait
    } else {
        Write-Host "No se encontró el desinstalador para la versión $Version. Procediendo a borrado manual de carpeta..." -ForegroundColor Yellow
        $FolderPath = "C:\Program Files (x86)\Microsoft\EdgeWebView\Application\$Version"
        if (Test-Path $FolderPath) {
            Remove-Item -Path $FolderPath -Recurse -Force
        }
    }
}
